@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(glm)

# vnm_plot_core PRIVATE-links Qt6::GuiPrivate. As a STATIC library that
# propagates via $<LINK_ONLY:>, so consumers of installed vnm_plot need the
# private Qt module available. GuiPrivate exposes unstable Qt internals.
find_dependency(Qt6 REQUIRED COMPONENTS Core Gui GuiPrivate Quick)

if(@VNM_PLOT_CONFIG_ENABLE_TEXT@)
    find_dependency(vnm_msdf_text)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/vnm_plotTargets.cmake")

check_required_components(vnm_plot)
